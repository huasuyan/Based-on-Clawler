<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace必须与Mapper接口的全限定类名一致 -->
<mapper namespace="com.crawler.mapper.XxlJobInfoMapper">


    <select id="selectByJobId" resultType="com.crawler.entity.xxljob.XxlJobInfo">
        select * from xxl_job_info where id = #{jobId}
    </select>
</mapper>